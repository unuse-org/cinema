# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
.utmp/
/cinema/[Ll]ibrary/
/cinema/[Tt]emp/
/cinema/[Oo]bj/
/cinema/[Bb]uild/
/cinema/[Bb]uilds/
/cinema/[Ll]ogs/
/cinema/[Uu]ser[Ss]ettings/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/cinema/[Mm]emoryCaptures/

# Recordings can get excessive in size
/cinema/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /cinema/[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/cinema/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
/cinema/ExportedObj/
/cinema/.consulo/
/cinema/*.csproj
/cinema/*.unityproj
/cinema/*.sln
/cinema/*.suo
/cinema/*.tmp
/cinema/*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/cinema/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/cinema/[Aa]ssets/[Ss]treamingAssets/aa.meta
/cinema/[Aa]ssets/[Ss]treamingAssets/aa/*


# WiFi
M5Stack-Atom-WiFi/.pio
M5Stack-Atom-WiFi/.vscode/.browse.c_cpp.db*
M5Stack-Atom-WiFi/.vscode/c_cpp_properties.json
M5Stack-Atom-WiFi/.vscode/launch.json
M5Stack-Atom-WiFi/.vscode/ipch
